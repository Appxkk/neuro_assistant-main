APP_ENV=local

AUTH_ENABLED=true
AUTH_SECRET_KEY=change_this_long_random_secret
AUTH_COOKIE_SECURE=false
AUTH_SESSION_MAX_AGE=86400

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_or_anon_key

LLM_PROVIDER=hybrid
LOCAL_PARSER_ENABLED=true

OLLAMA_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_UI_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=8

CLOUD_LLM_ENABLED=false
CLOUD_LLM_PROVIDER=openrouter
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=openrouter/free
CLOUD_LLM_TIMEOUT=12
CLOUD_LLM_HTTP_REFERER=https://neuro-assistant.local
CLOUD_LLM_TITLE=Neuro Assistant

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLLING_INTERVAL=5
